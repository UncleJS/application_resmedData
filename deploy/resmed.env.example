# ResMed Dashboard — runtime environment
# Copy this file to deploy/resmed.env and fill in your values.
# The resmed-web container reads this file via EnvironmentFile in its Quadlet unit.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=resmed
DB_PASSWORD=changeme
DB_NAME=resmed_sleep

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:4567
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=changeme

# ── App ──────────────────────────────────────────────────────────────────────
PORT=4567
NODE_ENV=production
